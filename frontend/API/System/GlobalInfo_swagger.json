{
    "swagger": "2.0",
    "info": {
        "description": "Ubik 系统全局信息接口文档",
        "title": "全局信息 API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8082",
    "basePath": "/api/v1",
    "paths": {
        "/contests/": {
            "get": {
                "description": "获取系统中所有的赛事列表，包括基本信息如赛事ID、名称、状态等",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Contests"
                ],
                "summary": "获取赛事列表",
                "responses": {
                    "200": {
                        "description": "成功反回赛事列表",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/model.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "msg": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/definitions/model.Track"
                                            }
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/tracks/{contest_id}": {
            "get": {
                "description": "获取指定赛事下的所有赛道列表，包括基本信息如赛道ID、名称、状态等",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Tracks"
                ],
                "summary": "获取赛道列表",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "赛事ID",
                        "name": "contest_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功返回赛道列表",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/model.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "msg": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/definitions/model.Track"
                                            }
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "model.Response": {
            "type": "object",
            "properties": {
                "code": {
                    "description": "状态码，和http状态码剥离，以分离网络和业务",
                    "type": "integer",
                    "example": 200
                },
                "msg": {
                    "description": "信息。可以是NULL，也可以是成功时返回的结构体，也可以是失败时的错误信息"
                }
            }
        },
        "model.Track": {
            "type": "object",
            "properties": {
                "contestID": {
                    "type": "integer"
                },
                "trackDescription": {
                    "description": "赛道描述",
                    "type": "string"
                },
                "trackID": {
                    "type": "integer"
                },
                "trackName": {
                    "description": "赛道名称",
                    "type": "string"
                },
                "trackSettings": {
                    "description": "赛道设置，存储为JSON格式",
                    "type": "object",
                    "additionalProperties": {}
                }
            }
        }
    }
}