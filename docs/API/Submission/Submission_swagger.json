{
    "swagger": "2.0",
    "info": {
        "description": "Ubik 稿件提交系统接口文档",
        "title": "作者端API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:80",
    "basePath": "/api/v1",
    "paths": {
        "/author": {
            "put": {
                "description": "更新作者信息接口，接受新的作者信息并更新数据库中的记录",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "作者端"
                ],
                "summary": "更新作者信息",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Bearer {access_token}",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "新的作者信息",
                        "name": "author",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.Author"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "更新成功",
                        "schema": {
                            "$ref": "#/definitions/model.Response"
                        }
                    }
                }
            }
        },
        "/author/login": {
            "post": {
                "description": "作者登录接口，返回访问令牌和刷新令牌",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "作者端"
                ],
                "summary": "作者登录",
                "parameters": [
                    {
                        "description": "作者登录信息",
                        "name": "author",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.Author"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "登录成功，返回访问令牌和刷新令牌",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/model.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "msg": {
                                            "$ref": "#/definitions/token.ResponseToken"
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/author/refresh": {
            "get": {
                "description": "刷新访问令牌，接受刷新令牌并返回新的访问令牌和刷新令牌",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "作者端"
                ],
                "summary": "刷新令牌",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Bearer {refresh_token}",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "刷新成功，返回新的访问令牌和刷新令牌",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/model.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "msg": {
                                            "$ref": "#/definitions/token.ResponseToken"
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/author/register": {
            "post": {
                "description": "作者注册接口，接受作者信息并创建新账号",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "作者端"
                ],
                "summary": "作者注册",
                "parameters": [
                    {
                        "description": "作者注册信息",
                        "name": "author",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.Author"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "注册成功",
                        "schema": {
                            "$ref": "#/definitions/model.Response"
                        }
                    }
                }
            }
        },
        "/author/submission": {
            "put": {
                "description": "更新提交记录接口，接受新的作品信息并更新数据库中的记录",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "作者端"
                ],
                "summary": "更新提交记录",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Bearer {access_token}",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "新的作品信息",
                        "name": "work",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.Work"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "更新成功，返回更新后的作品信息",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/model.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "msg": {
                                            "$ref": "#/definitions/model.Work"
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            },
            "post": {
                "description": "提交作品接口，接受作品信息和文件并创建新的作品记录",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "作者端"
                ],
                "summary": "提交作品",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Bearer {access_token}",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "作品信息",
                        "name": "work",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.Work"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "提交成功，返回提交的作品信息",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/model.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "msg": {
                                            "$ref": "#/definitions/model.Work"
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            },
            "delete": {
                "description": "删除提交记录接口，接受作品ID并删除对应的作品记录",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "作者端"
                ],
                "summary": "删除提交记录",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Bearer {access_token}",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "作品信息",
                        "name": "work",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.Work"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "删除成功",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/model.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "msg": {
                                            "type": "string"
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        },
        "/author/submission/file": {
            "post": {
                "description": "上传提交文件接口，接受作品ID和文件并保存到服务器",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "作者端"
                ],
                "summary": "上传提交文件",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Bearer {access_token}",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "作品ID",
                        "name": "work_id",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "file",
                        "description": "提交文件",
                        "name": "article_file",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "上传成功",
                        "schema": {
                            "$ref": "#/definitions/model.Response"
                        }
                    }
                }
            }
        },
        "/author/submission/{id}": {
            "get": {
                "description": "获取提交记录接口，返回作者的所有提交记录",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "作者端"
                ],
                "summary": "获取提交记录",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Bearer {access_token}",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "作者ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "获取成功，返回提交记录列表",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/model.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "msg": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/definitions/model.Work"
                                            }
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "model.Author": {
            "type": "object",
            "properties": {
                "authorEmail": {
                    "type": "string"
                },
                "authorID": {
                    "type": "integer"
                },
                "authorInfos": {
                    "type": "object",
                    "additionalProperties": {}
                },
                "authorName": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                },
                "penName": {
                    "type": "string"
                }
            }
        },
        "model.Response": {
            "type": "object",
            "properties": {
                "code": {
                    "description": "状态码，和http状态码剥离，以分离网络和业务",
                    "type": "integer",
                    "example": 200
                },
                "msg": {
                    "description": "信息。可以是NULL，也可以是成功时返回的结构体，也可以是失败时的错误信息"
                }
            }
        },
        "model.Work": {
            "type": "object",
            "properties": {
                "authorID": {
                    "type": "integer"
                },
                "trackID": {
                    "type": "integer"
                },
                "workID": {
                    "type": "integer"
                },
                "workInfos": {
                    "type": "object",
                    "additionalProperties": {}
                },
                "workTitle": {
                    "type": "string"
                }
            }
        },
        "token.ResponseToken": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string"
                },
                "refresh_token": {
                    "type": "string"
                }
            }
        }
    }
}